{
  "manifest_version": 3,
  "name": "Tab Manager with AI Summary",
  "version": "1.0.0",
  "description": "A Chrome extension to manage tabs with AI-powered summaries grouped by domain.",
  "permissions": [
    "tabs",
    "storage",
    "sidePanel"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Manager"
  },
  "side_panel": {
    "default_path": "sidePanel.html"
  },
  "options_page": "settings.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
